{
  "ignorePatterns": ["node_modules", "dist", "build", "coverage", ".expo"],
  "ignoreDirs": ["node_modules", "dist", "build", "coverage", ".expo", ".git", ".next"],
  "ignoreMatches": [
    "expo-font",
    "expo-system-ui",
    "expo-web-browser",
    "react-native-mmkv",
    "@commitlint/cli",
    "@commitlint/config-conventional",
    "commitlint",
    "jest-environment-jsdom",
    "@testing-library/react",
    "ts-jest",
    "globals"
  ]
}
