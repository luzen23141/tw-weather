{
  "name": "weather",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint app src --ignore-pattern '**/__tests__/**' --max-warnings=0",
    "lint:fix": "eslint app src --ignore-pattern '**/__tests__/**' --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.simple.js",
    "test:watch": "jest --config jest.config.simple.js --watch",
    "test:coverage": "jest --config jest.config.simple.js --coverage",
    "test:e2e:web": "playwright test",
    "test:e2e:mobile": "maestro test .maestro/",
    "check:unused": "knip",
    "check:updates": "npm-check-updates",
    "check:all": "pnpm lint && pnpm type-check && pnpm format:check && pnpm test && pnpm check:unused && pnpm check:import-meta",
    "check:all-short": "echo '=== lint ===' && eslint app src --ignore-pattern '**/__tests__/**' --max-warnings=0 --quiet && echo '=== type ===' && tsc --noEmit && echo '=== format ===' && prettier --check . --log-level error && echo '=== test ===' && jest --config jest.config.simple.js --silent --no-coverage 2>&1 | tail -3 && echo '=== unused ===' && knip && echo '=== import-meta ===' && node scripts/scan-prod-deps.js",
    "check:bundle": "bash scripts/bundle-scan.sh",
    "check:import-meta": "node scripts/scan-prod-deps.js",
    "check:security": "bash scripts/security-check.sh",
    "check:security:strict": "bash scripts/security-check.sh --strict",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/query-async-storage-persister": "^5.90.23",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.23",
    "expo": "~55.0.4",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-router": "~55.0.3",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.2",
    "react-native-css-interop": "^0.2.2",
    "react-native-mmkv": "^4.1.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "commitlint": "^20.4.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.0",
    "msw": "^2.12.10",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3"
  },
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "react-test-renderer": "19.2.4",
      "eslint-plugin-sonarjs>minimatch": ">=10.2.3",
      "jsdom": "^26.1.0"
    },
    "onlyBuiltDependencies": [
      "msw"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
